@page "/Cards/Thread/{threadId?}"

@using System.Net.Http.Json
@using MessageBoard.Models.ThreadModels
@using MessageBoard.Models.UserModels

@inject HttpClient Http
@inject AuthService Auth
@inject UserInformation UserInfo


<PageTitle>Thread Card</PageTitle>

<p>If you see this, the Thread card is working!</p>
<p>Title: @thrd!.Title<br />
Started by: @thrd!.CreatedByUserName at @thrd!.CreatedAt</p>


@code {
    [Parameter]
    public string threadId { get; set; } = "";
    private ThreadCardResponse? thrd;

    protected override void OnInitialized()
    {
        if (!Auth.isLoggedIn) {
            return;
        } else {
            Auth.ApplyAuthorization(Http);
        }

        if (string.IsNullOrEmpty(threadId)) {
            return;
        }

        Task<ThreadCardResponse?> response = Http.GetFromJsonAsync<ThreadCardResponse>(requestUri: "http://localhost:5063/api/threads/" + threadId  + "/card");
        
        response.ContinueWith(task =>
        {
            if (task.IsCompletedSuccessfully)
            {
                thrd = task.Result;
                StateHasChanged();
            }
        });

   // Initialization logic for the thread can be added here
    }
}
